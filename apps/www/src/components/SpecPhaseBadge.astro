---
interface Props {
  label: string;
}

const { label } = Astro.props as Props;
---

<span class="spec-phase-badge">{label}</span>

<style>
  .spec-phase-badge {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    border: 1px solid color-mix(in oklab, var(--color-primary) 42%, var(--color-border));
    border-radius: 999px;
    background: color-mix(in oklab, var(--color-primary) 8%, var(--color-background));
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    line-height: 1;
    padding: 0.25rem 0.5rem;
    vertical-align: middle;
  }
</style>
