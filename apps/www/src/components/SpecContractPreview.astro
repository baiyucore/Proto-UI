---
type ContractPreviewItem = {
  id: string;
  title: string;
  summary: string;
  quote?: string;
  criteria?: string[];
  tests?: string;
  source?: string;
};

interface Props {
  items: ContractPreviewItem[];
  locale?: 'en' | 'zh-cn';
}

const { items, locale = 'en' } = Astro.props as Props;

const labels =
  locale === 'zh-cn'
    ? {
        aria: '契约实体预览',
        eyebrow: '契约实体预览',
        excerpt: '摘录',
        criteria: '关键判定',
        tests: '测试映射',
        source: '来源',
      }
    : {
        aria: 'Contract entity previews',
        eyebrow: 'Contract entity preview',
        excerpt: 'Excerpt',
        criteria: 'Key criteria',
        tests: 'Test mapping',
        source: 'Source',
      };
---

<aside class="spec-contract-preview" aria-label={labels.aria}>
  <div class="spec-contract-preview__grid">
    {
      items.map((item) => (
        <article class="spec-contract-preview__item">
          <button class="spec-contract-preview__trigger" type="button">
            <span class="spec-contract-preview__id">{item.id}</span>
            <span class="spec-contract-preview__title">{item.title}</span>
          </button>
          <div class="spec-contract-preview__panel" role="note">
            <span class="spec-contract-preview__eyebrow">{labels.eyebrow}</span>
            <strong>{item.id}</strong>
            <p>{item.summary}</p>
            {item.quote && (
              <blockquote>
                <span>{labels.excerpt}</span>
                {item.quote}
              </blockquote>
            )}
            {item.criteria && item.criteria.length > 0 && (
              <div>
                <span class="spec-contract-preview__label">{labels.criteria}</span>
                <ul>
                  {item.criteria.map((criterion) => (
                    <li>{criterion}</li>
                  ))}
                </ul>
              </div>
            )}
            {item.tests && (
              <p class="spec-contract-preview__meta">
                <span>{labels.tests}</span>
                {item.tests}
              </p>
            )}
            {item.source && (
              <p class="spec-contract-preview__source">
                <span>{labels.source}</span>
                <code>{item.source}</code>
              </p>
            )}
          </div>
        </article>
      ))
    }
  </div>
</aside>

<style>
  .spec-contract-preview {
    margin-block: 1.5rem 2rem;
  }

  .spec-contract-preview__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 15rem), 1fr));
    gap: 0.75rem;
  }

  .spec-contract-preview__item {
    position: relative;
    min-width: 0;
  }

  .spec-contract-preview__trigger {
    display: grid;
    width: 100%;
    min-height: 5.75rem;
    gap: 0.45rem;
    align-content: start;
    border: 1px solid color-mix(in oklab, var(--color-border) 82%, transparent);
    border-radius: 0.5rem;
    background: color-mix(in oklab, var(--color-background) 94%, var(--color-muted) 6%);
    color: var(--color-foreground);
    padding: 0.85rem 0.9rem;
    text-align: left;
    box-shadow: none;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      transform 160ms ease;
  }

  .spec-contract-preview__trigger:hover,
  .spec-contract-preview__trigger:focus-visible {
    border-color: color-mix(in oklab, var(--color-primary) 70%, var(--color-border));
    background: color-mix(in oklab, var(--color-primary) 8%, var(--color-background));
    outline: none;
    transform: translateY(-1px);
  }

  .spec-contract-preview__id {
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: 0.77rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .spec-contract-preview__title {
    display: -webkit-box;
    overflow: hidden;
    color: var(--color-foreground);
    font-size: 0.9rem;
    font-weight: 650;
    line-height: 1.35;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .spec-contract-preview__panel {
    position: absolute;
    left: 50%;
    top: calc(100% + 0.55rem);
    z-index: 35;
    display: grid;
    gap: 0.7rem;
    width: min(29rem, calc(100vw - 2rem));
    border: 1px solid color-mix(in oklab, var(--color-border) 86%, transparent);
    border-radius: 0.5rem;
    background: var(--color-background);
    box-shadow:
      0 18px 48px rgba(15, 23, 42, 0.14),
      0 4px 14px rgba(15, 23, 42, 0.1);
    opacity: 0;
    padding: 1rem;
    pointer-events: none;
    translate: -50% 0.35rem;
    transition:
      opacity 160ms ease,
      translate 160ms ease;
  }

  [data-theme='dark'] .spec-contract-preview__panel {
    box-shadow:
      0 18px 48px rgba(0, 0, 0, 0.46),
      0 4px 14px rgba(0, 0, 0, 0.3);
  }

  .spec-contract-preview__item:hover .spec-contract-preview__panel,
  .spec-contract-preview__item:focus-within .spec-contract-preview__panel {
    opacity: 1;
    pointer-events: auto;
    translate: -50% 0;
  }

  .spec-contract-preview__eyebrow,
  .spec-contract-preview__label,
  .spec-contract-preview__meta span,
  .spec-contract-preview__source span,
  .spec-contract-preview blockquote span {
    color: var(--color-muted-foreground);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .spec-contract-preview__panel strong {
    color: var(--color-foreground);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .spec-contract-preview__panel p,
  .spec-contract-preview__panel li,
  .spec-contract-preview__source code {
    color: var(--color-muted-foreground);
    font-size: 0.84rem;
    line-height: 1.55;
  }

  .spec-contract-preview__panel p {
    margin: 0;
  }

  .spec-contract-preview__panel ul {
    margin: 0.35rem 0 0 1.1rem;
    padding: 0;
  }

  .spec-contract-preview__panel li {
    margin-top: 0.25rem;
  }

  .spec-contract-preview blockquote {
    display: grid;
    gap: 0.35rem;
    margin: 0;
    border-left: 2px solid color-mix(in oklab, var(--color-primary) 70%, var(--color-border));
    padding-left: 0.75rem;
    color: var(--color-foreground);
    font-size: 0.86rem;
    font-style: normal;
    line-height: 1.55;
  }

  .spec-contract-preview__meta,
  .spec-contract-preview__source {
    display: grid;
    gap: 0.25rem;
  }

  @media (max-width: 48rem) {
    .spec-contract-preview__panel {
      position: static;
      width: 100%;
      margin-top: 0.5rem;
      opacity: 1;
      pointer-events: auto;
      translate: none;
    }
  }
</style>
