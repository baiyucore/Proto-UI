{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@proto.ui/core/internal": ["packages/core/src/internal.ts"],
      "@proto.ui/spec-*": ["packages/spec/*/src"],
      "@proto.ui/spec-engine/*": ["packages/spec/engine/src/*"],
      "@proto.ui/spec-fixtures/*": ["packages/spec/fixtures/src/*"],
      "@proto.ui/spec-graph/*": ["packages/spec/graph/src/*"],
      "@proto.ui/spec-schema/*": ["packages/spec/schema/src/*"],
      "@proto.ui/module-*": ["packages/modules/*/src"],
      "@proto.ui/adapter-*": ["packages/adapters/*/src"],
      "@proto.ui/prototypes-base": ["packages/prototypes/base/src/index.ts"],
      "@proto.ui/prototypes-shadcn": ["packages/prototypes/shadcn/src/index.ts"],
      "@proto.ui/prototypes-lucide": ["packages/prototypes/lucide/src/index.ts"],
      "@proto.ui/prototypes-lucide/*": ["packages/prototypes/lucide/src/*"],
      "@proto.ui/prototypes-*": ["packages/prototypes/*/src"],
      "@proto.ui/*": [
        "packages/*/src",
        "packages/modules/*/src",
        "packages/adapters/*/src",
        "packages/legacy/*/src"
      ]
    },
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  }
}
